# ============================================================
# MeetingBro Configuration Template
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.
# ============================================================

# LLM / Summary / Translation (optional)
# Supports any OpenAI-compatible API (OpenAI, LongCat, Ollama, etc.)
# If left empty, summaries fall back to local heuristics.
MEETINGBRO_LLM_API_KEY=your_api_key_here
MEETINGBRO_LLM_BASE_URL=https://api.openai.com/v1
MEETINGBRO_LLM_MODEL=gpt-4o-mini

# ── Whisper ASR ──────────────────────────────────────────────
# Model size: tiny | base | small | medium | large-v2 | auto
MEETINGBRO_WHISPER_SIZE=auto
MEETINGBRO_WHISPER_BEAM_SIZE=3

# ── Audio chunking ───────────────────────────────────────────
MEETINGBRO_CHUNK_SECONDS=0.5
MEETINGBRO_ASR_ACCUM_SECONDS=2.0
MEETINGBRO_SILENCE_RMS_THRESHOLD=0.001
MEETINGBRO_ASR_OVERLAP_SECONDS=0.0

# ── Voice Activity Detection (VAD) ───────────────────────────
MEETINGBRO_PRE_VAD_ENABLED=true
MEETINGBRO_PRE_VAD_TRAILING_SILENCE_SECONDS=0.50
MEETINGBRO_PRE_VAD_MAX_SEGMENT_SECONDS=8

# ── Live Translation ─────────────────────────────────────────
MEETINGBRO_TRANSLATION_EXECUTOR_WORKERS=2
MEETINGBRO_LIVE_TRANSLATION_BACKFILL_LIMIT=20
MEETINGBRO_LIVE_TRANSLATION_MAX_PENDING=12

# ── Segment quality filters ──────────────────────────────────
MEETINGBRO_SUSPICIOUS_SEGMENT_NO_SPEECH_PROB=0.6
MEETINGBRO_SUSPICIOUS_SEGMENT_AVG_LOGPROB=-0.9
MEETINGBRO_SUSPICIOUS_SEGMENT_COMPRESSION_RATIO=2.1

# ── Audio denoising (experimental) ───────────────────────────
MEETINGBRO_DENOISE_ENABLED=false
MEETINGBRO_DENOISE_STRENGTH=1.1
MEETINGBRO_DENOISE_NOISE_UPDATE_RMS_THRESHOLD=0.02

# ── Speaker diarization ──────────────────────────────────────
MEETINGBRO_ENABLE_DIARIZATION=false
# MEETINGBRO_VOCABULARY_HINT=OpenAI, Anthropic, Teams, Zoom, BBB

# ── Audio conditioning ───────────────────────────────────────
MEETINGBRO_AUDIO_CONDITIONING_ENABLED=true
MEETINGBRO_AUDIO_CONDITIONING_TARGET_RMS=0.035
MEETINGBRO_AUDIO_CONDITIONING_MIN_RMS=0.003
MEETINGBRO_AUDIO_CONDITIONING_MAX_GAIN=2.5
MEETINGBRO_AUDIO_CONDITIONING_PEAK_LIMIT=0.98
MEETINGBRO_PRE_VAD_CONDITIONING_ENABLED=true
MEETINGBRO_PRE_VAD_CONDITIONING_TARGET_RMS=0.03
MEETINGBRO_PRE_VAD_CONDITIONING_MIN_RMS=0.001
MEETINGBRO_PRE_VAD_CONDITIONING_MAX_GAIN=4.0
MEETINGBRO_PRE_VAD_THRESHOLD=0.38
MEETINGBRO_PRE_VAD_ENERGY_RMS_THRESHOLD=0.005
MEETINGBRO_WHISPER_VAD_THRESHOLD=0.3

# ── Language detection ───────────────────────────────────────
# Set to true to lock to a single language (faster, less drift)
MEETINGBRO_LANGUAGE_LOCK_ENABLED=false
MEETINGBRO_ASR_RETRY_ENABLED=true

# ── Realtime safeguard ───────────────────────────────────────
MEETINGBRO_ASR_SAFEGUARD_ENABLED=true
MEETINGBRO_ASR_SAFEGUARD_RTF_THRESHOLD=0.9
MEETINGBRO_ASR_SAFEGUARD_COOLDOWN_WINDOWS=5
MEETINGBRO_LIVE_TRANSLATION_SAFEGUARD_MAX_PENDING=4

# ── Weak voice rescue ────────────────────────────────────────
MEETINGBRO_WEAK_SPEECH_RESCUE_ENABLED=true
MEETINGBRO_WEAK_SPEECH_RESCUE_RMS_MIN=0.0008
MEETINGBRO_WEAK_SPEECH_RESCUE_RMS_MAX=0.02
MEETINGBRO_WEAK_SPEECH_RESCUE_WINDOW_SECONDS=6
MEETINGBRO_WEAK_SPEECH_RESCUE_COOLDOWN_SECONDS=8

# ── Runtime profile ──────────────────────────────────────────
# Options: balanced | robust | fast | low_latency
MEETINGBRO_RUNTIME_PROFILE=balanced
MEETINGBRO_WHISPER_DEVICE=auto
MEETINGBRO_WHISPER_COMPUTE_TYPE=auto
MEETINGBRO_WHISPER_NUM_WORKERS=1

# ── Preview ASR (fast subtitles) ─────────────────────────────
MEETINGBRO_PREVIEW_WHISPER_SIZE=tiny
MEETINGBRO_PREVIEW_WHISPER_MULTILINGUAL=true
MEETINGBRO_PREVIEW_WHISPER_BEAM_SIZE=1
MEETINGBRO_PREVIEW_ASR_EXECUTOR_WORKERS=1
MEETINGBRO_AUDIO_INPUT_QUEUE_MAX_SECONDS=10
MEETINGBRO_AUDIO_INPUT_QUEUE_WARNING_SECONDS=3
MEETINGBRO_FAST_PREVIEW_WINDOW_SECONDS=2.0
MEETINGBRO_FAST_PREVIEW_INTERVAL_SECONDS=0.7

# ── Early flush / silence commit ─────────────────────────────
MEETINGBRO_ASR_EARLY_FLUSH_ENABLED=true
MEETINGBRO_ASR_EARLY_FLUSH_MIN_SECONDS=1.0
MEETINGBRO_SILENCE_COMMIT_MIN_CONFIDENCE=0.78
MEETINGBRO_SILENCE_COMMIT_MIN_DURATION_SECONDS=0.70
MEETINGBRO_PRE_VAD_ADAPTIVE_FAST_TRAILING_SILENCE_SECONDS=0.30
MEETINGBRO_FAST_PREVIEW_MAX_BACKLOG_SECONDS=2.0
MEETINGBRO_FAST_PREVIEW_MAX_ASR_RTF=1.2
MEETINGBRO_FAST_PREVIEW_MIN_RMS=0.006

# ── Qwen3 preview ASR (experimental, optional) ───────────────
# Requires downloading the sherpa-onnx Qwen3 model first.
# See README for download instructions.
# Set to "whisper" to use Whisper-based preview instead.
MEETINGBRO_PREVIEW_ASR_BACKEND=qwen3
MEETINGBRO_PREVIEW_QWEN3_MODEL_DIR=models/sherpa-onnx-qwen3-asr-0.6B-int8-2026-03-25
MEETINGBRO_PREVIEW_QWEN3_NUM_THREADS=2
MEETINGBRO_PREVIEW_QWEN3_PROVIDER=cpu
MEETINGBRO_PREVIEW_QWEN3_MAX_TOTAL_LEN=512
MEETINGBRO_PREVIEW_QWEN3_MAX_NEW_TOKENS=256
MEETINGBRO_PREVIEW_QWEN3_FILTER_LANGUAGE_SCRIPT=true
MEETINGBRO_PREVIEW_QWEN3_SUPPRESS_FILLERS=true
MEETINGBRO_PREVIEW_QWEN3_PREWARM=true
MEETINGBRO_PREVIEW_FALLBACK_ON_ERROR=false
